# Base URL de l'API SIC (backend Django) — IMPORTANT: suffixe /api (pas /api/v1)
#
# - Emulateur Android      : http://10.0.2.2:8000/api
# - Telephone physique USB : http://<IP_LAN_DU_PC>:8000/api   (ex: http://192.168.1.20:8000/api)
# - iOS simulateur / Web   : http://localhost:8000/api
#
# Copier ce fichier en `.env` et ajuster API_BASE_URL selon la cible.
API_BASE_URL=http://10.0.2.2:8000/api
API_TIMEOUT=30000
ENV=development

# Monitoring d'erreurs (optionnel). Laisser vide en dev : Sentry reste inactif.
# SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/XXXX
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.2
