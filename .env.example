# =============================================================================
# SIC - Variables d'Environnement
# =============================================================================
# Copiez ce fichier vers .env et remplissez les valeurs
# IMPORTANT: Ne JAMAIS commiter le fichier .env avec les vraies valeurs !
# =============================================================================

# -----------------------------------------------------------------------------
# SÉCURITÉ - Obligatoire en production
# -----------------------------------------------------------------------------

# Clé secrète Django (générez une nouvelle clé pour chaque environnement)
# Python: from django.core.management.utils import get_random_secret_key
SECRET_KEY=votre-cle-secrete-a-changer-en-production

# Mode debug (True en développement, False en production)
DEBUG=True

# Hôtes autorisés (séparés par des virgules, sans espaces)
# En production, spécifiez les domaines exacts
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------

USE_DOCKER=False

# -----------------------------------------------------------------------------
# BASE DE DONNÉES - PostgreSQL (OBLIGATOIRE)
# -----------------------------------------------------------------------------

# Option 1: DATABASE_URL (format complet)
DATABASE_URL=postgresql://sic_user:8258@localhost:5432/sic_db

# Option 2: Configuration explicite (si DATABASE_URL non défini)
# POSTGRES_DB=sic_db
# POSTGRES_USER=sic_user
# POSTGRES_PASSWORD=8258
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# JWT - Authentification
# -----------------------------------------------------------------------------

# Durée de vie du token d'accès (en minutes)
JWT_ACCESS_LIFETIME_MINUTES=60

# Durée de vie du token de rafraîchissement (en jours)
JWT_REFRESH_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# CORS - Cross-Origin Resource Sharing
# -----------------------------------------------------------------------------

# Origines autorisées (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# CELERY - Tâches asynchrones
# -----------------------------------------------------------------------------

# URL du broker Redis
CELERY_BROKER_URL=redis://localhost:6379/0

# URL du backend Redis pour les résultats
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# CINETPAY - Paiements mobile money
# -----------------------------------------------------------------------------

# Identifiants CinetPay (obtenus depuis votre dashboard CinetPay)
CINETPAY_API_KEY=votre-api-key-cinetpay
CINETPAY_SITE_ID=votre-site-id-cinetpay
CINETPAY_SECRET_KEY=votre-secret-key-cinetpay

# URL de base API CinetPay
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

# URLs de callback (doivent être accessibles depuis Internet en production)
CINETPAY_NOTIFY_URL=http://localhost:8000/api/transactions/webhook/
CINETPAY_RETURN_URL=http://localhost:8000/dashboard/

# -----------------------------------------------------------------------------
# COMMISSIONS - Taux de commission par type de transaction
# -----------------------------------------------------------------------------

# Dépôt (en pourcentage)
COMMISSION_DEPOT_SIC=1.0      # 1% pour SIC
COMMISSION_DEPOT_AGENT=0.5    # 0.5% pour l'agent

# Retrait (en pourcentage)
COMMISSION_RETRAIT_SIC=1.5    # 1.5% pour SIC
COMMISSION_RETRAIT_AGENT=0.5  # 0.5% pour l'agent

# Transfert (en pourcentage)
COMMISSION_TRANSFERT_SIC=0.5
COMMISSION_TRANSFERT_AGENT=0.0

# Conversion/Swap (en pourcentage)
COMMISSION_SWAP_SIC=0.5
COMMISSION_SWAP_AGENT=0.0

# -----------------------------------------------------------------------------
# LIMITES DE TRANSACTION
# -----------------------------------------------------------------------------

# Montant maximum par transaction (FCFA)
MAX_TRANSACTION_AMOUNT=5000000

# Timeout des transactions en attente (minutes)
TRANSACTION_TIMEOUT_MINUTES=5

# Nombre maximum de puces par agent
MAX_PUCES_PER_AGENT=5

# -----------------------------------------------------------------------------
# CONFIGURATION OPTIONNELLE
# -----------------------------------------------------------------------------

# Email pour les notifications (optionnel)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=votre-email@gmail.com
# EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
# EMAIL_FROM=noreply@sic-platform.com